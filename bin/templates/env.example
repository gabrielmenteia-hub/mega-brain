# ══════════════════════════════════════════════════════════════
# MEGA BRAIN - Environment Configuration
# Run 'npx mega-brain-ai setup' to configure interactively
# ══════════════════════════════════════════════════════════════

# === REQUIRED (pipeline won't work without this) ===
# OpenAI Whisper — video/audio transcription
# Essential for /ingest with YouTube videos and audio files
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# === RECOMMENDED (full power, but works without) ===
# Voyage AI — semantic embeddings for RAG search
# Without this, semantic search uses mock vectors (degraded quality)
# Get yours at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=

# === OPTIONAL (convenience features) ===
# Google OAuth — import transcriptions from Drive
# Without these, download files manually to inbox/
# Setup at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === NOT NEEDED WITH CLAUDE CODE ===
# Only for standalone Python scripts outside Claude Code
# ANTHROPIC_API_KEY=

# === MIS — MARKET INTELLIGENCE SYSTEM ===
# Required for platform scanners that use official APIs

# Product Hunt API Token — trending products scanner (Phase 15)
# Scanner degrades gracefully (returns []) when absent
# Get yours at: https://www.producthunt.com/v2/oauth/applications
# Note: Developer token does not expire
PRODUCT_HUNT_API_TOKEN=

# Udemy Affiliate API credentials (Phase 15)
# IMPORTANT: Udemy Affiliate API was deprecated on 2025-01-01
# Scanner will return [] with alert='api_discontinued' if credentials are invalid
# Legacy credentials (issued before 2025) may still work
# Get yours at: https://www.udemy.com/affiliate/tools/api/ (if still accessible)
UDEMY_CLIENT_ID=
UDEMY_CLIENT_SECRET=
