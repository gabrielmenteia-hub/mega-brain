# NEXUS Pipeline Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Required ────────────────────────────────────────────────────────────────
# Anthropic API key for Claude models (required)
NEXUS_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Review Thresholds (defaults shown) ──────────────────────────────────────
# Minimum score (1-10) required for each review dimension to approve a creative.
# Copy: Hook, CTA, persuasion, length fit
NEXUS_MIN_COPY_SCORE=7

# Tech: Audio quality, video sync, format compliance
NEXUS_MIN_TECH_SCORE=6

# Compliance: Legal claims, platform policy, brand guidelines
NEXUS_MIN_COMPLIANCE_SCORE=8

# Performance: Predicted CTR, engagement signals
NEXUS_MIN_PERFORMANCE_SCORE=6

# ─── Pipeline Control ─────────────────────────────────────────────────────────
# Maximum number of regeneration attempts before quarantining a creative
NEXUS_MAX_REVIEW_ATTEMPTS=3

# Claude model to use for review agents
NEXUS_REVIEW_MODEL=claude-sonnet-4-20250514

# ─── Paths ────────────────────────────────────────────────────────────────────
# Directory where approved creatives and review reports are written
NEXUS_OUTPUT_DIR=output
