# ─────────────────────────────────────────────
# AlphaChat Backend — Variáveis de Ambiente
# Copie para .env e preencha com seus valores
# ─────────────────────────────────────────────

# Supabase (Settings → API no dashboard)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...          # anon key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service role key

# Supabase JWT (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Pinecone (app.pinecone.io)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=alphachat-knowledge

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — embeddings only (platform.openai.com)
OPENAI_API_KEY=sk-...

# Stripe (dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...    # ID do price Pro no Stripe
STRIPE_PRICE_MASTER=price_... # ID do price Master no Stripe
